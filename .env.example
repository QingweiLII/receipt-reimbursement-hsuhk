HOST=127.0.0.1
PORT=8000

# mock refuses extraction until a real provider is configured.
# fixture is only for the five included sample files in this workspace.
LLM_PROVIDER=openai
LLM_API_KEY=replace-me
LLM_MODEL=gpt-4o-mini

# For OpenAI-compatible APIs, use:
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=https://your-provider.example/v1

# Other supported providers:
# LLM_PROVIDER=minimax
# LLM_BASE_URL=https://api.minimax.io/anthropic
# LLM_API_KEY=replace-me
# LLM_MODEL=MiniMax-M2.7
# LLM_MAX_TOKENS=2500
#
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-sonnet-latest
#
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-1.5-pro

# Optional public-link guard. Leave unset if colleagues can open the page directly.
# If set, open /?token=the-secret-token.
# APP_TOKEN=the-secret-token

# HKD conversion.
# Default: Frankfurter historical rates, no API key required.
EXCHANGE_RATE_PROVIDER=frankfurter
FX_BASE_URL=https://api.frankfurter.dev/v2
FX_LOOKBACK_DAYS=7

# Optional fallback/static mode:
# EXCHANGE_RATE_PROVIDER=static
# FX_RATES_JSON={"USD":7.8,"CNY":1.08,"DKK":1.14,"SGD":5.75}

MAX_UPLOAD_MB=20
MAX_PARALLEL_RECEIPTS=1
UPLOAD_JOB_WORKERS=1
MAX_ACTIVE_UPLOAD_JOBS=8
MAX_FILES_PER_UPLOAD=10
LLM_TIMEOUT_SECONDS=45
OCR_FALLBACK_ON_LLM_ERROR=true
RECEIPT_PROCESS_TIMEOUT_SECONDS=120

# OCR tuning for small cloud instances.
OCR_TARGET_MIN_EDGE=500
OCR_MAX_LONG_EDGE=900
OCR_SMALL_MAX_LONG_EDGE=650
OCR_SMALL_RETRY=true
OCR_VARIANTS=gray
OCR_PSMS=6,11
OCR_TIMEOUT_SECONDS=20
OCR_MAX_CANDIDATES=3

# Local mode writes records under data/. Cloud deployment can use each user's
# own Google Drive via OAuth.
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=user_google_drive
# PUBLIC_BASE_URL=https://your-render-url.onrender.com
# GOOGLE_OAUTH_CLIENT_ID=replace-me.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=replace-me
# GOOGLE_DRIVE_FOLDER_NAME=HSUHK Receipt Reports

# Older shared-admin Google Sheet mode is also available if you explicitly want
# one service-account-owned sheet for all users.
# STORAGE_PROVIDER=google_sheets
# GOOGLE_SHEET_ID=replace-me
# GOOGLE_SHEET_NAME=Receipts
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
